{
  "name": "Command_plus_API",
  "version": "1.1.0",
  "description": "Command+ API - Extensible cross-platform CLI tool",
  "main": "index.js",
  "bin": {
    "c": "./index.js"
  },
  "scripts": {
    "start": "node index.js",
    "build": "pkg . --out-path dist",
    "build:win": "pkg . -t node18-win-x64 -o dist/c.exe",
    "build:mac": "pkg . -t node18-macos-x64 -o dist/c",
    "build:linux": "pkg . -t node18-linux-x64 -o dist/c"
  },
  "dependencies": {
    "compressing": "^1.10.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "pkg": {
    "scripts": [
      "index.js"
    ],
    "targets": [
      "node16-win-x64",
      "node16-macos-x64",
      "node16-linux-x64"
    ],
    "outputPath": "dist"
  }
}